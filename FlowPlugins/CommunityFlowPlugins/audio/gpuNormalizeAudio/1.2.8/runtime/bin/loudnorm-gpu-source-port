#!/usr/bin/env python3
from __future__ import annotations

import os
import sys
import time

from cuda_buffers import allocate_runtime_buffers, free_runtime_buffers
from cuda_kernels import load_kernel_set
from device_setup import build_kernel_arg_bindings, close_cuda_session, create_host_io_buffers, free_host_io_buffers, initialize_runtime_buffers, open_cuda_session
from first_pass_json import emit_first_pass_input_json, emit_first_pass_json
from loudnorm_math import ebur128_filter_coeffs
from runtime_config import apply_stats_result_to_config, derive_runtime_config, parse_runtime_args
from runtime_modes import RuntimeModeContext, run_gain_and_apply_stage, run_stats_stage
from runtime_profile import emit_runtime_summary
from short_source_exact import try_short_source_exact
from stats_cache import read_stats_cache_header

def _env_flag(name, default=False):
    value = os.environ.get(name)
    if value is None:
        return default
    return value.lower() in ('1', 'true', 'yes', 'on')


def _env_float(name, default):
    value = os.environ.get(name)
    if value is None:
        return default
    try:
        return float(value)
    except ValueError:
        return default


_PROGRESS_THROTTLE = _env_flag('LOUDNORM_GPU_RUNTIME_PROGRESS_THROTTLE', True)
_PROGRESS_MIN_DELTA = max(0.0, _env_float('LOUDNORM_GPU_RUNTIME_PROGRESS_MIN_DELTA', 0.01))
_PROGRESS_MIN_INTERVAL_SEC = max(0.0, _env_float('LOUDNORM_GPU_RUNTIME_PROGRESS_MIN_INTERVAL_MS', 2000.0)) / 1000.0
_PROGRESS_LAST = {}


def emit_tdarr_progress(phase, fraction):
    value = min(1.0, max(0.0, float(fraction)))
    if _PROGRESS_THROTTLE:
        now = time.perf_counter()
        last = _PROGRESS_LAST.get(phase)
        should_emit = (
            last is None
            or value <= 0.0
            or value >= 1.0
            or value < last[0]
            or (value - last[0]) >= _PROGRESS_MIN_DELTA
            or (now - last[1]) >= _PROGRESS_MIN_INTERVAL_SEC
        )
        if not should_emit:
            return
        _PROGRESS_LAST[phase] = (value, now)
    print(f'tdarr_progress phase={phase} fraction={value:.6f}', file=sys.stderr, flush=True)


def main():
    args = parse_runtime_args()
    start_wall = time.perf_counter()
    cfg = derive_runtime_config(args)
    if cfg.stats_cache_header_sizing:
        cfg = apply_stats_result_to_config(cfg, read_stats_cache_header(args.stats_cache_input, args, cfg))

    if try_short_source_exact(args, cfg, emit_tdarr_progress):
        return
    b_coeffs, a_coeffs = ebur128_filter_coeffs(args.rate)

    cuda_session = open_cuda_session(args)
    try:
        cuda = cuda_session.cuda
        kernels = load_kernel_set(cuda, cuda_session.module, args, cfg)
        buffers, state_bytes = allocate_runtime_buffers(cuda, args, cfg)
        try:
            initialize_runtime_buffers(
                cuda,
                args,
                buffers,
                cfg=cfg,
                state_bytes=state_bytes,
                b_coeffs=b_coeffs,
                a_coeffs=a_coeffs,
            )
            kernel_arg_bindings = build_kernel_arg_bindings(args, buffers, cfg)
            host_io = create_host_io_buffers(cuda, cfg)

            mode_ctx = RuntimeModeContext(
                cuda=cuda,
                cuda_session=cuda_session,
                args=args,
                cfg=cfg,
                buffers=buffers,
                kernels=kernels,
                bindings=kernel_arg_bindings,
                state_bytes=state_bytes,
                host_io=host_io,
                b_coeffs=b_coeffs,
                a_coeffs=a_coeffs,
            )
            stats_stage = run_stats_stage(mode_ctx, emit_tdarr_progress)
            cfg = mode_ctx.cfg
            stats_result = stats_stage.stats_result
            gain_metrics = stats_stage.gain_metrics
            apply_result = stats_stage.apply_result

            if args.emit_first_pass_input_json:
                emit_first_pass_input_json(cuda, args, cfg, buffers)
            elif not args.stats_cache_only:
                apply_stage = run_gain_and_apply_stage(mode_ctx, emit_tdarr_progress)
                cfg = mode_ctx.cfg
                gain_metrics = apply_stage.gain_metrics
                apply_result = apply_stage.apply_result
                emit_first_pass_json(cuda, args, cfg, buffers, apply_result)
        finally:
            if 'host_io' in locals():
                free_host_io_buffers(cuda, host_io)
            free_runtime_buffers(cuda, buffers)
    finally:
        close_cuda_session(cuda_session)

    elapsed = time.perf_counter() - start_wall
    emit_runtime_summary(
        args,
        cfg,
        gpu_name=cuda_session.gpu_name,
        elapsed=elapsed,
        stats_result=stats_result,
        gain_metrics=gain_metrics,
        apply_result=apply_result,
        bindings=kernel_arg_bindings,
    )
    if _env_flag('LOUDNORM_GPU_RUNTIME_HARD_EXIT_AFTER_SUCCESS', True):
        sys.stdout.flush()
        sys.stderr.flush()
        os._exit(0)


if __name__ == '__main__':
    main()
